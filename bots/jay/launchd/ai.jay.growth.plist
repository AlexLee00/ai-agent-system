<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
                       "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>ai.jay.growth</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/homebrew/bin/mix</string>
		<string>jay.growth_cycle.run</string>
		<string>--no-actions</string>
		<string>--no-notify</string>
		<string>--no-clean-day</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Users/alexlee/projects/ai-agent-system/elixir/team_jay</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/alexlee</string>
		<key>MIX_ENV</key>
		<string>prod</string>
		<key>JAY_V2_ENABLED</key>
		<string>true</string>
		<key>JAY_COMMANDER_ENABLED</key>
		<string>false</string>
		<key>TEAM_JAY_ENABLE_ALARM_DELIVERY</key>
		<string>false</string>
		<key>JAY_LLM_DAILY_BUDGET_USD</key>
		<string>5.00</string>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
		<key>REPO_ROOT</key>
		<string>/Users/alexlee/projects/ai-agent-system</string>
	</dict>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>6</integer>
		<key>Minute</key>
		<integer>30</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>/tmp/jay-growth.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/jay-growth.err.log</string>
	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
