{
  "name": "블로그팀 동적 포스팅",
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "path": "blog-pipeline",
        "httpMethod": "POST",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "split-pipeline",
      "name": "파이프라인 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "// 웹훅 입력 파싱\nconst body = $input.item.json.body || $input.item.json;\nconst {\n  postType,\n  sessionId,\n  pipeline,\n  variations,\n  category,\n  lectureNumber,\n  lectureTitle,\n  topic,\n} = body;\n\nreturn [{\n  json: {\n    postType,\n    sessionId,\n    pipeline,\n    variations,\n    category: category || null,\n    lectureNumber: lectureNumber || null,\n    lectureTitle: lectureTitle || null,\n    topic: topic || category || lectureTitle || (postType === 'lecture' ? 'Node.js' : '일반 포스팅'),\n  }\n}];"
      }
    },
    {
      "id": "node-weather",
      "name": "날씨 수집",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 160],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3100/api/blog/node/weather",
        "sendBody": true,
        "bodyContentType": "json",
        "body": {
          "sessionId": "={{ $('파이프라인 파싱').item.json.sessionId }}"
        }
      }
    },
    {
      "id": "node-it-news",
      "name": "IT뉴스 수집",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
