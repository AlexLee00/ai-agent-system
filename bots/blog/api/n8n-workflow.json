        "body": {
          "sessionId": "={{ $('파이프라인 파싱').item.json.sessionId }}",
          "topic": "={{ $('파이프라인 파싱').item.json.topic }}",
          "postType": "={{ $('파이프라인 파싱').item.json.postType }}"
        }
      }
    },
    {
      "id": "node-related",
      "name": "관련 포스팅",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 440],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3100/api/blog/node/related-posts",
        "sendBody": true,
        "bodyContentType": "json",
        "body": {
          "sessionId": "={{ $('파이프라인 파싱').item.json.sessionId }}",
          "topic": "={{ $('파이프라인 파싱').item.json.topic }}",
          "lectureNumber": "={{ $('파이프라인 파싱').item.json.lectureNumber }}"
        }
      }
    },
    {
      "id": "node-write",
      "name": "글 생성",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1120, 300],
      "parameters": {
        "method": "POST",
        "url": "=http://localhost:3100/api/blog/node/write-{{ $('파이프라인 파싱').item.json.postType === 'lecture' ? 'lecture' : 'general' }}",
        "sendBody": true,
        "bodyContentType": "json",
        "body": {
          "sessionId": "={{ $('파이프라인 파싱').item.json.sessionId }}",
          "category": "={{ $('파이프라인 파싱').item.json.category || '자기계발' }}",
          "lectureNumber": "={{ $('파이프라인 파싱').item.json.lectureNumber || 1 }}",
          "lectureTitle": "={{ $('파이프라인 파싱').item.json.lectureTitle || 'Node.js 기초' }}",
          "sectionVariation": "={{ $('파이프라인 파싱').item.json.variations }}"
        }
      }
    },
    {
      "id": "node-quality",
      "name": "품질 검증",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1340, 300],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3100/api/blog/node/quality-check",
        "sendBody": true,
        "bodyContentType": "json",
        "body": {
          "sessionId": "={{ $('파이프라인 파싱').item.json.sessionId }}",
          "postType": "={{ $('파이프라인 파싱').item.json.postType }}"
        }
      }
    },
    {
      "id": "respond-webhook",
      "name": "완료 응답",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1560, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, sessionId: $('파이프라인 파싱').item.json.sessionId, quality: $('품질 검증').item.json }) }}"
      }
    }
  ],
