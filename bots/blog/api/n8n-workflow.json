        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { sessionId: $('파이프라인 파싱').item.json.sessionId, category: $('파이프라인 파싱').item.json.category || '자기계발', lectureNumber: $('파이프라인 파싱').item.json.lectureNumber || 1, lectureTitle: $('파이프라인 파싱').item.json.lectureTitle || 'Node.js 기초', sectionVariation: $('파이프라인 파싱').item.json.variations } }}",
