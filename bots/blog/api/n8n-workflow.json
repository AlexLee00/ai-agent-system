      "parameters": {
        "method": "POST",
        "url": "http://localhost:3100/api/blog/node/it-news",
        "sendBody": true,
        "bodyContentType": "json",
        "body": {
          "sessionId": "={{ $('파이프라인 파싱').item.json.sessionId }}"
        }
      }
    },
    {
      "id": "node-nodejs",
      "name": "Node.js 업데이트 수집",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 440],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3100/api/blog/node/nodejs-updates",
        "sendBody": true,
        "bodyContentType": "json",
        "body": {
          "sessionId": "={{ $('파이프라인 파싱').item.json.sessionId }}"
        }
      }
    },
    {
      "id": "node-rag-exp",
      "name": "RAG 실전 사례",
