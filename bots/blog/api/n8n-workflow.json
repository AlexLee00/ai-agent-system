{
  "name": "블로그팀 동적 포스팅",
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "path": "blog-pipeline",
        "httpMethod": "POST",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "split-pipeline",
      "name": "파이프라인 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "// 웹훅 입력 파싱\nconst body = $input.item.json.body || $input.item.json;\nconst {\n  postType,\n  sessionId,\n  pipeline,\n  variations,\n  category,\n  lectureNumber,\n  lectureTitle,\n  topic,\n  postId,\n  scheduleId,\n  publishedUrl,\n  url,\n} = body;\n\nreturn [{\n  json: {\n    postType,\n    sessionId,\n    pipeline,\n    variations,\n    category: category || null,\n    lectureNumber: lectureNumber || null,\n    lectureTitle: lectureTitle || null,\n    topic: topic || category || lectureTitle || (postType === 'lecture' ? 'Node.js' : '일반 포스팅'),\n    postId: postId || null,\n    scheduleId: scheduleId || null,\n    publishedUrl: publishedUrl || url || null,\n  }\n}];"
      }
    },
    {
      "id": "if-published-url",
      "name": "발행 URL 포함?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $('파이프라인 파싱').item.json.publishedUrl || '' }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      }
    },
    {
      "id": "node-mark-published",
      "name": "발행 URL 기록",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 180],
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:3100/api/blog/mark-published",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { postId: $('파이프라인 파싱').item.json.postId, scheduleId: $('파이프라인 파싱').item.json.scheduleId, url: $('파이프라인 파싱').item.json.publishedUrl } }}",
        "options": {}
      }
    },
    {
      "id": "node-weather",
      "name": "날씨 수집",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 320],
