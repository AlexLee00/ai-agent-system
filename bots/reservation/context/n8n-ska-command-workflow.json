              "value1": "={{$json.command}}",
              "operation": "equal",
              "value2": "query_alerts"
            }
          ]
        }
      },
      "id": "IF_Alerts",
      "name": "알람 조회?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1160, 540]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{`SELECT type, title, message, timestamp FROM reservation.alerts WHERE resolved = 0 ORDER BY timestamp DESC LIMIT ${$json.limit}`}}"
      },
      "id": "PG_Alerts",
      "name": "알람 조회",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1400, 480],
      "credentials": {
        "postgres": {
          "id": "__POSTGRES_CREDENTIAL_ID__",
          "name": "Team Jay PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(item => item.json);\nreturn [{ json: { ok: true, count: rows.length, alerts: rows, past_cases: null, source: 'n8n' } }];"
      },
      "id": "Code_Alerts",
      "name": "알람 결과 포맷",
