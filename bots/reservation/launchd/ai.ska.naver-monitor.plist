<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.ska.naver-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/alexlee/projects/ai-agent-system/bots/reservation/auto/monitors/start-ops.sh</string>
    </array>

    <!-- 상시 실행: 죽으면 자동 재시작 -->
    <key>KeepAlive</key>
    <true/>

    <!-- 로그인 시 자동 시작 -->
    <key>RunAtLoad</key>
    <true/>

    <!-- 재시작 최소 간격 10초 (크래시 루프 방지) -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/tmp/naver-ops-mode.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/naver-ops-mode.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/alexlee</string>
        <key>PATH</key>
        <string>/Users/alexlee/.nvm/versions/node/v24.13.1/bin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>PICKKO_HEADLESS</key>
        <string>1</string>
        <key>PICKKO_ENABLE</key>
        <string>1</string>
        <key>PICKKO_CANCEL_ENABLE</key>
        <string>1</string>

    </dict>
</dict>
</plist>
