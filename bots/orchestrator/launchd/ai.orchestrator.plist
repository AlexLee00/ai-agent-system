  <key>StandardErrorPath</key>
  <string>/Users/alexlee/.openclaw/logs/mainbot-error.log</string>

  <!-- 시스템 부팅 또는 로그인 시 자동 시작 -->
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
