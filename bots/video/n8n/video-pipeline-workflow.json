      "id": "video-parse",
      "name": "요청 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "const payload = $input.item.json.body || $input.item.json;\nconst headers = $input.item.json.headers || payload.headers || {};\nconst providedToken = headers['x-video-token'] || headers['X-Video-Token'] || '';\nconst expectedToken = '__VIDEO_N8N_TOKEN__';\nconst probeHeader = headers['x-health-probe'] || headers['X-Health-Probe'] || '';\n\nreturn [{\n  json: {\n    sessionId: payload.sessionId ? Number(payload.sessionId) : null,\n    pairIndex: payload.pairIndex ? Number(payload.pairIndex) : null,\n    editId: payload.editId ? Number(payload.editId) : null,\n    sourceVideoPath: payload.sourceVideoPath || '',\n    sourceAudioPath: payload.sourceAudioPath || '',\n    title: payload.title || '',\n    editNotes: payload.editNotes || '',\n    introMode: payload.introMode || 'none',\n    introFilePath: payload.introFilePath || '',\n    introPrompt: payload.introPrompt || '',\n    introDurationSec: payload.introDurationSec ? Number(payload.introDurationSec) : null,\n    introLogoPath: payload.introLogoPath || '',\n    outroMode: payload.outroMode || 'none',\n    outroFilePath: payload.outroFilePath || '',\n    outroPrompt: payload.outroPrompt || '',\n    outroDurationSec: payload.outroDurationSec ? Number(payload.outroDurationSec) : null,\n    outroLogoPath: payload.outroLogoPath || '',\n    skipRender: Boolean(payload.skipRender),\n    healthProbe: Boolean(payload._healthProbe) || probeHeader === '1',\n    tokenValid: Boolean(expectedToken) && providedToken === expectedToken\n  }\n}];"
      }
    },
    {
      "id": "video-auth-if",
      "name": "토큰 유효?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.tokenValid}}",
              "operation": "true"
            }
          ]
        }
      }
    },
    {
