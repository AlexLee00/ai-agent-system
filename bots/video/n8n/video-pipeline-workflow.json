        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Video-Token",
              "value": "__VIDEO_N8N_TOKEN__"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={{$json}}",
        "options": {}
      }
