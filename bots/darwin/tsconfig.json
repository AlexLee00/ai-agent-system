{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "__tests__/research-monitor-smoke.test.ts",
    "__tests__/research-task-runner-smoke.test.ts",
    "lib/autonomy-level.ts",
    "lib/proposal-store.ts",
    "lib/research-monitor.ts",
    "lib/research-tasks.ts",
    "lib/research-scanner.ts",
    "lib/keyword-evolver.ts",
    "lib/arxiv-client.ts",
    "lib/event-reminders.ts",
    "lib/hf-papers-client.ts",
    "lib/research-evaluator.ts",
    "lib/applicator.ts",
    "lib/implementor.ts",
    "lib/verifier.ts",
    "scripts/research-task-runner.ts",
    "scripts/darwin-weekly-ops-report.ts",
    "scripts/darwin-weekly-review.ts",
    "src/signal-receiver.ts"
  ],
  "exclude": [
    "**/node_modules/**"
  ]
}
