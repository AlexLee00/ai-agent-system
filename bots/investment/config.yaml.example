# 루나팀 Phase 3-A 설정 — 예시 파일 (실제 키 없음)
# ⚠️ config.yaml은 .gitignore에 포함 — 절대 커밋 금지
# 사용법: cp config.yaml.example config.yaml → 실제 키 입력

trading_mode: paper
binance_mode: inherit
kis_mode: inherit
paper_mode: true

anthropic:
  api_key: "sk-ant-api03-YOUR_KEY_HERE"

groq:
  accounts:
    - api_key: "gsk_YOUR_KEY_1"
    - api_key: "gsk_YOUR_KEY_2"
    - api_key: "gsk_YOUR_KEY_3"
    - api_key: "gsk_YOUR_KEY_4"

cerebras:
  api_key: "csk-YOUR_KEY_HERE"

sambanova:
  api_key: "YOUR-UUID-HERE"

xai:
  api_key: "xai-YOUR_KEY_HERE"

telegram:
  bot_token: "BOT_TOKEN_HERE"
  chat_id: 0

binance:
  api_key: "YOUR_BINANCE_API_KEY"
  api_secret: "YOUR_BINANCE_API_SECRET"
  testnet: true   # 레거시 실험용 플래그. 현재 운영 분류의 brokerAccountMode에는 사용하지 않음
  symbols:
    - "BTC/USDT"
    - "ETH/USDT"
    - "SOL/USDT"
    - "BNB/USDT"
  # deposit_address_usdt: bots/hub/secrets-store.json → investment_accounts.binance

upbit:
  access_key: "YOUR_UPBIT_ACCESS_KEY"
  secret_key: "YOUR_UPBIT_SECRET_KEY"

kis:
  app_key: "YOUR_KIS_APP_KEY"
  app_secret: "YOUR_KIS_APP_SECRET"
  paper_app_key: "YOUR_KIS_PAPER_APP_KEY"
  paper_app_secret: "YOUR_KIS_PAPER_APP_SECRET"
  # account_number: bots/hub/secrets-store.json → investment_accounts.kis
  # paper_account_number: bots/hub/secrets-store.json → investment_accounts.kis
  symbols:
    - "005930"
    - "000660"
  overseas_symbols:
    - "AAPL"
    - "TSLA"
    - "NVDA"

news:
  naver_client_id: "YOUR_NAVER_CLIENT_ID"
  naver_client_secret: "YOUR_NAVER_CLIENT_SECRET"
  dart_api_key: ""
  cryptopanic_api_key: ""
  alpha_vantage_api_key: ""

cost:
  daily_budget_paper:   0.05
  daily_budget_live:    0.10
  monthly_budget_paper: 1.00
  monthly_budget_live:  2.00

# Position Lifecycle Kill Switches (Phase A~H)
# 기본값은 모두 shadow/safe mode입니다. 운영 전 각 Phase별 smoke 통과 후 단계적으로 켭니다.
position_lifecycle:
  adaptive_cadence:
    enabled: false
    default_cadence_ms: 300000
    event_cadence_ms: 60000
    burst_cadence_ms: 30000
  strategy_validity:
    enabled: false
    hold_threshold: 0.7
    caution_threshold: 0.5
    pivot_threshold: 0.3
    exit_threshold: 0.3
  strategy_mutation:
    enabled: false
    predictive_threshold: 0.55
    daily_limit: 5
  signal_refresh:
    enabled: false
    max_per_run: 10
    min_attention_score: 0.55
  dynamic_position_sizing:
    enabled: false
    max_trim_ratio: 0.5
    max_pyramid_ratio: 0.25
    kelly_half_cap: 0.3
  dynamic_trailing:
    enabled: false
    atr_multiplier: 2.5
    chandelier_multiplier: 3.0
  reflexive_portfolio_monitoring:
    enabled: false
    max_correlation: 0.85
    max_concentration_pct: 0.35
    max_drawdown_chain_count: 3
  event_stream:
    enabled: false
    persist_stage_events: true
  mode: shadow
