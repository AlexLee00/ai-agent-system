  </dict>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/tmp/ai.luna.guard-outcome-tracker-daily-0900.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/ai.luna.guard-outcome-tracker-daily-0900.err.log</string>
