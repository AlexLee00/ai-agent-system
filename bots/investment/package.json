{
  "name": "@ai-agent/investment",
  "version": "2.1.0",
  "description": "🌙 루나팀 Phase 3-A — 암호화폐·국내외주식 자동매매 (PAPER_MODE 기본값)",
  "main": "markets/crypto.js",
  "type": "module",
  "scripts": {
    "crypto": "PAPER_MODE=false node markets/crypto.js",
    "domestic": "PAPER_MODE=false node markets/domestic.js",
    "overseas": "PAPER_MODE=false node markets/overseas.js",
    "luna": "PAPER_MODE=false node team/luna.js --symbols=BTC/USDT",
    "aria": "node team/aria.js --symbol=BTC/USDT",
    "oracle": "node team/oracle.js --symbol=BTC/USDT",
    "hermes": "node team/hermes.js --symbol=BTC/USDT",
    "sophia": "node team/sophia.js --symbol=BTC/USDT",
    "nemesis": "node team/nemesis.js",
    "check": "node --check markets/crypto.js && node --check team/luna.js && node --check shared/llm-client.js",
    "report": "node team/reporter.js",
    "report:tg": "node team/reporter.js --telegram",
    "journal": "node scripts/trading-journal.js",
    "journal:week": "node scripts/trading-journal.js --days=7",
    "journal:all": "node scripts/trading-journal.js --all",
    "journal:tg": "node scripts/trading-journal.js --telegram",
    "review": "node scripts/weekly-trade-review.js",
    "review:dry": "node scripts/weekly-trade-review.js --dry-run",
    "review:2w": "node scripts/weekly-trade-review.js --days=14",
    "runtime-suggest": "node scripts/runtime-config-suggestions.js",
    "node:run": "node scripts/run-pipeline-node.js",
    "node:l01": "node scripts/run-pipeline-node.js --node=L01 --market=binance",
    "node:l06": "node scripts/run-pipeline-node.js --node=L06 --market=binance",
    "inspect-logs": "node scripts/inspect-market-logs.js",
    "inspect-logs:domestic": "node scripts/inspect-market-logs.js --market=domestic",
    "inspect-logs:overseas": "node scripts/inspect-market-logs.js --market=overseas",
    "validate-review": "node scripts/validate-trade-review.js",
    "validate-review:fix": "node scripts/validate-trade-review.js --fix",
    "analyze-rr": "node scripts/analyze-rr.js",
    "analyze-rr:30": "node scripts/analyze-rr.js --days=30",
    "analyze-signals": "node scripts/analyze-signal-correlation.js",
    "analyze-signals:30": "node scripts/analyze-signal-correlation.js --days=30"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "axios": "^1.6.0",
    "ccxt": "^4.5.42",
    "groq-sdk": "^1.1.1",
    "js-yaml": "^4.1.0",
    "nyse-holidays": "^1.2.0",
    "openai": "^6.29.0",
    "pg": "^8.20.0"
  }
}
