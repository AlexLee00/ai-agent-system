{
  "name": "@ai-agent/investment",
  "version": "2.1.0",
  "description": "🌙 루나팀 Phase 3-A — 암호화폐·국내외주식 자동매매 (PAPER_MODE 기본값)",
  "main": "markets/crypto.ts",
  "type": "module",
  "scripts": {
    "crypto": "PAPER_MODE=false node markets/crypto.ts",
    "domestic": "PAPER_MODE=false node markets/domestic.ts",
    "overseas": "PAPER_MODE=false node markets/overseas.ts",
    "luna": "PAPER_MODE=false node team/luna.ts --symbols=BTC/USDT",
    "aria": "node team/aria.ts --symbol=BTC/USDT",
    "oracle": "node team/oracle.ts --symbol=BTC/USDT",
    "hermes": "node team/hermes.ts --symbol=BTC/USDT",
    "sophia": "node team/sophia.ts --symbol=BTC/USDT",
    "scout": "node team/scout.ts --dry-run --json",
    "nemesis": "node team/nemesis.ts",
    "chronos": "node team/chronos.ts --symbol=BTC/USDT --from=2026-03-01 --to=2026-04-01 --layer=3",
    "chronos:quality": "node team/chronos.ts --symbol=BTC/USDT --from=2026-03-01 --to=2026-04-01 --layer=3 --measure-quality",
    "check": "node --check markets/crypto.ts && node --check team/luna.ts && node --check shared/llm-client.ts",
    "report": "node team/reporter.ts",
    "report:tg": "node team/reporter.ts --telegram",
    "journal": "node scripts/trading-journal.ts",
    "journal:week": "node scripts/trading-journal.ts --days=7",
    "journal:all": "node scripts/trading-journal.ts --all",
    "journal:tg": "node scripts/trading-journal.ts --telegram",
    "review": "node scripts/weekly-trade-review.ts",
    "review:dry": "node scripts/weekly-trade-review.ts --dry-run",
    "review:2w": "node scripts/weekly-trade-review.ts --days=14",
    "daily-feedback": "node scripts/daily-trade-feedback.ts",
    "daily-feedback:dry": "node scripts/daily-trade-feedback.ts --dry-run",
    "planner:smoke": "node scripts/analysis-planner-smoke.ts",
    "planner:dryrun": "node scripts/pre-screen-planner-dryrun.ts",
    "planner:bridge-smoke": "node scripts/pre-screen-planner-bridge-smoke.ts --market=binance --research-only --regime=volatile --fear-greed=88 --symbol-count=3",
    "planner:session-smoke": "node scripts/planner-session-smoke.ts --market=binance --research-only --regime=volatile --fear-greed=88 --symbol-count=3",
    "planner:session-suite": "node scripts/planner-session-suite.ts",
    "planner:sessions": "node scripts/planner-session-report.ts --limit=10",
    "planner:decision-smoke": "node scripts/decision-planner-smoke.ts",
    "planner:decision-suite": "node scripts/decision-planner-suite.ts",
    "planner:e2e": "node scripts/planner-e2e-scenario.ts",
    "parallel-snapshot": "node scripts/parallel-ops-snapshot.ts",
    "parallel-report": "node scripts/parallel-ops-report.ts",
    "parallel-history": "node scripts/parallel-ops-history.ts",
    "runtime-suggest": "node scripts/runtime-config-suggestions.ts",
    "runtime-suggest:write": "node scripts/runtime-config-suggestions.ts --write",
    "runtime-suggest:review": "node scripts/review-runtime-config-suggestion.ts",
    "runtime-suggest:apply": "node scripts/apply-runtime-config-suggestion.ts",
    "runtime-suggest:validate": "node scripts/validate-runtime-config-apply.ts",
    "node:run": "node scripts/run-pipeline-node.ts",
    "node:l01": "node scripts/run-pipeline-node.ts --node=L01 --market=binance",
    "node:l06": "node scripts/run-pipeline-node.ts --node=L06 --market=binance",
    "inspect-logs": "node scripts/inspect-market-logs.ts",
    "inspect-logs:domestic": "node scripts/inspect-market-logs.ts --market=domestic",
    "inspect-logs:overseas": "node scripts/inspect-market-logs.ts --market=overseas",
    "validate-review": "node scripts/validate-trade-review.ts",
    "validate-review:fix": "node scripts/validate-trade-review.ts --fix",
    "analyze-rr": "node scripts/analyze-rr.ts",
    "analyze-rr:30": "node scripts/analyze-rr.ts --days=30",
    "analyze-rr:validate": "node scripts/analyze-rr.ts --validate-backtest",
    "analyze-rr:validate-only": "node scripts/analyze-rr.ts --validate-backtest-only",
    "backtest:vectorbt": "python3 scripts/backtest-vectorbt.py --symbol BTC/USDT --days 30",
    "backtest:vectorbt:grid": "python3 scripts/backtest-vectorbt.py --symbol BTC/USDT --days 90 --grid",
    "optimize-ta": "node scripts/optimize-ta-params.ts",
    "optimize-ta:no-alert": "node scripts/optimize-ta-params.ts --no-alert",
    "tradingview-mcp:test": "python3 scripts/tradingview-mcp-server.py --test --json",
    "analyze-signals": "node scripts/analyze-signal-correlation.ts",
    "analyze-signals:30": "node scripts/analyze-signal-correlation.ts --days=30"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "axios": "^1.6.0",
    "ccxt": "^4.5.42",
    "groq-sdk": "^1.1.1",
    "js-yaml": "^4.1.0",
    "nyse-holidays": "^1.2.0",
    "openai": "^6.29.0",
    "pg": "^8.20.0"
  }
}
