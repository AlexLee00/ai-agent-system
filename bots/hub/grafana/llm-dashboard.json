{
  "title": "Team Jay — LLM Hub",
  "uid": "teamjay-llm-hub",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "provider",
        "type": "query",
        "query": "label_values(llm_circuit_state, provider)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Circuit Breaker 상태",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "targets": [
        { "expr": "llm_circuit_state{provider=~\"$provider\"}", "legendFormat": "{{provider}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "HALF_OPEN", "color": "yellow" }, "2": { "text": "OPEN", "color": "red" } } }
          ],
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 2, "color": "red" }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Provider 실패율",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "targets": [
        { "expr": "llm_failure_rate{provider=~\"$provider\"}", "legendFormat": "{{provider}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.1, "color": "yellow" }, { "value": 0.3, "color": "red" }] }
        }
      }
    },
    {
      "id": 3,
      "title": "평균 레이턴시 (ms)",
      "type": "bargauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "targets": [
        { "expr": "llm_avg_latency_ms{provider=~\"$provider\"}", "legendFormat": "{{provider}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 3000, "color": "yellow" }, { "value": 10000, "color": "red" }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Circuit Breaker 상태 이력",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "llm_circuit_state{provider=~\"$provider\"}", "legendFormat": "{{provider}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED" }, "1": { "text": "HALF_OPEN" }, "2": { "text": "OPEN" } } }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "팀별 일일 LLM 비용 (USD)",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "llm_daily_cost_usd", "legendFormat": "{{team}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 6,
      "title": "Provider 평균 레이턴시 추이",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        { "expr": "llm_avg_latency_ms{provider=~\"$provider\"}", "legendFormat": "{{provider}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineWidth": 2 },
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 5000, "color": "yellow" }, { "value": 15000, "color": "red" }] }
        }
      }
    }
  ]
}
