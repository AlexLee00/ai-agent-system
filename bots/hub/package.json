{
  "name": "@team-jay/hub",
  "version": "1.0.0",
  "private": true,
  "description": "Resource API Hub for OPS resource proxy",
  "main": "src/hub.ts",
  "scripts": {
    "start": "tsx src/hub.ts",
    "alarm:digest-worker": "tsx scripts/alarm-digest-worker.ts",
    "alarm:noise-report": "tsx scripts/alarm-noise-report.ts",
    "alarm:stale-auto-repair": "tsx scripts/alarm-auto-repair-stale-scan.ts",
    "alarm:suppression-proposals": "tsx scripts/alarm-suppression-proposals.ts",
    "alarm:suppression-apply": "tsx scripts/alarm-suppression-proposals.ts --apply",
    "alarm:contract-audit": "tsx scripts/alarm-contract-audit.ts",
    "alarm:readiness": "tsx scripts/alarm-readiness-report.ts",
    "readiness": "tsx scripts/hub-readiness-report.ts",
    "live:drill": "tsx scripts/hub-live-drill.ts",
    "live:drill:mock": "HUB_LIVE_DRILL_MOCK=1 HUB_AUTH_TOKEN=hub-live-drill-mock-token tsx scripts/hub-live-drill.ts",
    "team:llm-drill": "tsx scripts/team-llm-route-drill.ts",
    "team:llm-drill:live": "HUB_TEAM_LLM_DRILL_LIVE=1 tsx scripts/team-llm-route-drill.ts",
    "agent:hub-transition-audit": "tsx scripts/agent-hub-transition-audit.ts",
    "transition:completion-gate": "tsx scripts/hub-transition-completion-gate.ts",
    "oauth:team-readiness": "tsx scripts/team-oauth-readiness-report.ts",
    "oauth:monitor": "tsx scripts/run-oauth-monitor.ts",
    "telegram:routing-readiness": "tsx scripts/telegram-routing-readiness-report.ts",
    "telegram:team-topic-monitor": "tsx scripts/telegram-team-topic-monitor.ts",
    "telegram:retired-topic-janitor": "tsx scripts/telegram-retired-topic-janitor.ts",
    "telegram:ensure-class-topics": "tsx scripts/telegram-ensure-class-topics.ts",
    "launchd:alarm-class-topic": "tsx scripts/launchd-alarm-class-topic-smoke.ts",
    "local-llm-policy": "tsx scripts/local-llm-policy-report.ts",
    "inventory:hub-alarm": "tsx scripts/generate-hub-alarm-inventory.ts",
    "retired-gateway:residue-audit": "tsx scripts/retired-gateway-residue-audit.ts",
    "retired-gateway:cutover-readiness": "tsx scripts/retired-gateway-cutover-readiness.ts",
    "retired-gateway:archive-home": "tsx scripts/retired-gateway-home-archive.ts",
    "retired-gateway:cleanup-worktrees": "tsx scripts/retired-gateway-worktree-cleanup.ts",
    "ops:closeout": "tsx scripts/hub-ops-closeout.ts",
    "ops:closeout:live-llm": "HUB_OPS_CLOSEOUT_LIVE_LLM=1 tsx scripts/hub-ops-closeout.ts --live-llm",
    "test": "tsx scripts/run-tests.ts all",
    "test:unit": "tsx scripts/run-tests.ts unit",
    "test:secrets-meta": "node --test __tests__/secrets-meta.node.test.js",
    "check:runtime": "tsx scripts/run-tests.ts runtime",
    "check:runtime:live-llm": "tsx scripts/run-tests.ts runtime-live",
    "check:l5": "tsx scripts/run-tests.ts all && tsx scripts/run-tests.ts runtime && tsx scripts/generate-hub-alarm-inventory.ts",
    "check:l5:live-llm": "tsx scripts/run-tests.ts all && tsx scripts/run-tests.ts runtime-live && tsx scripts/generate-hub-alarm-inventory.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "tsx": "^4.21.0"
  }
}
