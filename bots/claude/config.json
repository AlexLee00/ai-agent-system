  "runtime_config": {
    "thresholds": {
      "diskMinMB": 500,
      "logMaxMB": 50,
      "errorRateWarn": 10,
      "errorRateCrit": 30,
      "memMinFreeGB": 2,
      "npmAuditLevel": "high"
    },
    "patterns": {
      "patternDays": 7,
      "newErrorHours": 8,
      "errorThreshold": 5,
      "warnThreshold": 3,
      "cleanupDays": 30
    },
    "quickcheck": {
      "alertCooldownMs": 3600000,
      "restartCooldownMs": 1800000,
      "maxRestarts": 3,
      "diskCriticalPercent": 90
    },
    "autonomy": {
      "adaptiveLead": {
        "enabled": true,
        "baseMode": "auto_all",
        "degradedMode": "auto_low",
        "restartTimeoutWindowMinutes": 15,
        "restartTimeoutFailThreshold": 3,
        "degradeOnCritical": true,
        "degradeOnHubControlPlane": true,
        "degradeOnCodeIntegrity": true
      }
    },
