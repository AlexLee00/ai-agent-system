<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.sigma.weekly-review</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/tsx</string>
    <string>/Users/alexlee/projects/ai-agent-system/bots/sigma/ts/src/sigma-weekly-review.ts</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/alexlee/projects/ai-agent-system</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>/Users/alexlee</string>
    <key>MODE</key>
    <string>ops</string>
    <key>SIGMA_TELEGRAM_ENHANCED</key>
    <string>true</string>
    <key>SIGMA_HTTP_PORT</key>
    <string>4010</string>
    <key>HUB_BASE_URL</key>
    <string>http://localhost:7788</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/tmp/sigma-weekly-review.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/sigma-weekly-review.err.log</string>

  <!-- 매주 일요일 19:00 KST (UTC 일요일 10:00) -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>0</integer>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
