  <key>StandardOutPath</key>
  <string>/tmp/sigma-mcp-server.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/sigma-mcp-server.err.log</string>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
