# Sigma V2 Kill Switches
# 프로덕션 배포 시 전체 제어 — 30초 내 롤백 가능

SIGMA_V2_ENABLED=false            # Phase 0에서는 false, Phase 1부터 점진 true
SIGMA_TIER2_AUTO_APPLY=false      # Phase 3 진입 후 true
SIGMA_GEPA_ENABLED=false          # (= ESPL) Phase 4 진입 후 true
SIGMA_MCP_SERVER_ENABLED=false    # Phase 5 진입 후 true
SIGMA_SELF_RAG_ENABLED=false      # Phase 3 진입 후 true

# Budget enforcement (docs/design/DESIGN_SIGMA_PRINCIPLES.yaml.example §6)
SIGMA_LLM_DAILY_BUDGET_USD=10.00
SIGMA_LLM_MONTHLY_BUDGET_USD=180.00
