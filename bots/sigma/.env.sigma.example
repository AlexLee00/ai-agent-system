# Sigma V2 Kill Switches
# 프로덕션 배포 시 전체 제어 — 30초 내 롤백 가능

SIGMA_V2_ENABLED=false            # Phase 0에서는 false, Phase 1부터 점진 true
SIGMA_TIER2_AUTO_APPLY=false      # Phase 3 진입 후 true
SIGMA_GEPA_ENABLED=false          # (= ESPL) Phase 4 진입 후 true
SIGMA_MCP_SERVER_ENABLED=false    # Phase 5 진입 후 true
SIGMA_SELF_RAG_ENABLED=false      # Phase 3 진입 후 true

# Intelligent Library / Great Library Brain
# 기본은 shadow + no mutation. PII/민감 export/헌법만 안전 기본 ON.
SIGMA_LIBRARY_AUTONOMY_MODE=shadow
SIGMA_TEAM_MEMORY_UNIFIED=false
SIGMA_KNOWLEDGE_GRAPH_ENABLED=false
SIGMA_DATASET_BUILDER_ENABLED=false
SIGMA_DATASET_AUTO_EXPORT=false
SIGMA_SELF_IMPROVEMENT_ENABLED=false
SIGMA_VOYAGER_SKILL_AUTO_EXTRACTION=false
SIGMA_FINE_TUNING_NOTIFY_ENABLED=false
SIGMA_MULTI_HOP_RAG_ENABLED=false
SIGMA_HYDE_ENABLED=false
SIGMA_DATA_LINEAGE_ENABLED=false
SIGMA_PII_REDACTION_ENABLED=true
SIGMA_SENSITIVE_EXPORT_BLOCKED=true
SIGMA_CONSTITUTION_ENABLED=true
SIGMA_CONSTITUTION_VIOLATION_AUTO_BLOCK=false
SIGMA_LIBRARY_DASHBOARD_ENABLED=false

# Budget enforcement (docs/design/DESIGN_SIGMA_PRINCIPLES.yaml.example §6)
SIGMA_LLM_DAILY_BUDGET_USD=10.00
SIGMA_LLM_MONTHLY_BUDGET_USD=180.00
SIGMA_ENTITY_EXTRACTION_LLM_DAILY_BUDGET_USD=2.00
SIGMA_SELF_IMPROVEMENT_LLM_DAILY_BUDGET_USD=5.00
