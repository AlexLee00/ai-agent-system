{
  "name": "ai-agent-system",
  "version": "1.0.0",
  "description": "멀티 에이전트 AI 봇 시스템",
  "private": true,
  "workspaces": [
    "packages/*",
    "bots/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "weekly-report": "node scripts/weekly-team-report.js",
    "weekly-report:30": "node scripts/weekly-team-report.js --days=30"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "tar": "^7.5.9"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "technicalindicators": "^3.1.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
