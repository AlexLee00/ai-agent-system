# 팀 제이 ai-agent-system 환경변수 목록
# 실제 값은 .env.development / .env.production 에 작성
# 두 파일 모두 Git에 올라가지 않음

# ─── 실행 환경 (필수) ────────────────────────────────────────────────
PROJECT_ROOT=
MODE=
PAPER_MODE=
NODE_ENV=

# ─── n8n ────────────────────────────────────────────────────────────
N8N_ENABLED=
N8N_BASE_URL=
N8N_EMAIL=
N8N_PASSWORD=

# ─── PostgreSQL ─────────────────────────────────────────────────────
PG_HOST=
PG_PORT=
PG_USER=
PG_DATABASE=

# ─── 알림 ────────────────────────────────────────────────────────────
TELEGRAM_CHAT_ID=

# ─── 구글 드라이브 ───────────────────────────────────────────────────
GDRIVE_BLOG_DIR=
GDRIVE_BLOG_IMAGES=
GDRIVE_BLOG_INSTA=

# ─── 블로그 ──────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=
BLOG_LLM_MODEL=

# ─── Resource API Hub ────────────────────────────────────────────────
HUB_BASE_URL=
HUB_AUTH_TOKEN=
HUB_PORT=
