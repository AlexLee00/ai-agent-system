{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "maxNodeModuleJsDepth": 0,
    "types": ["node"]
  },
  "files": [
    "packages/core/lib/central-logger.js",
    "packages/core/lib/openclaw-client.js",
    "packages/core/lib/llm-model-selector.js",
    "packages/core/lib/llm-fallback.js",
    "packages/core/lib/rag.js",
    "packages/core/lib/message-envelope.core.ts",
    "packages/core/lib/event-lake.core.ts",
    "packages/core/lib/hiring-contract.core.ts",
    "packages/core/lib/pg-pool.core.ts",
    "bots/investment/shared/market-regime.core.ts",
    "bots/investment/shared/trade-journal-db.js",
    "bots/investment/team/nemesis.js",
    "bots/investment/team/luna.js",
    "bots/investment/team/scout.js",
    "bots/claude/src/dexter.js",
    "bots/claude/lib/doctor.js",
    "bots/orchestrator/lib/research/research-tasks.js"
  ],
  "exclude": [
    "**/node_modules/**",
    "bots/worker/web/**"
  ]
}
