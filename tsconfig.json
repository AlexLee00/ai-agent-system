{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "maxNodeModuleJsDepth": 0,
    "types": ["node"]
  },
  "files": [
    "packages/core/lib/event-lake.js",
    "packages/core/lib/hiring-contract.js",
    "packages/core/lib/central-logger.js",
    "packages/core/lib/openclaw-client.js",
    "packages/core/lib/llm-model-selector.js",
    "packages/core/lib/llm-fallback.js",
    "packages/core/lib/rag.js",
    "packages/core/lib/message-envelope.js",
    "bots/investment/shared/market-regime.js",
    "bots/investment/shared/trade-journal-db.js"
  ],
  "exclude": [
    "**/node_modules/**",
    "bots/worker/web/**"
  ]
}
