#!/bin/bash
# pre-commit hook — Security by Design
# 설치: bash scripts/setup-hooks.sh
# 또는: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
BLOCKED=0

echo "🔒 보안 검사 실행 중..."

# ─── 1. 금지 파일 차단 ────────────────────────────────────────────────────
BLOCKED_FILES=(
  "secrets.json"
  "config.yaml"
  ".env"
  ".env.local"
  ".env.production"
  "state.db"
  "state.db-wal"
  "state.db-shm"
  "pending-telegrams.jsonl"
  "bug-tracker.json"
  "paired.json"
)

STAGED=$(git diff --cached --name-only 2>/dev/null)
STAGED_DELETIONS=$(git diff --cached --diff-filter=D --name-only 2>/dev/null)

for pattern in "${BLOCKED_FILES[@]}"; do
  # 파일명이 패턴과 정확히 일치하는 경우 (경로 무관)
  # 삭제(D)는 안전하므로 제외 — git rm --cached (추적 해제) 커밋은 허용
  if echo "$STAGED" | grep -qE "(^|/)${pattern}$"; then
    if echo "$STAGED_DELETIONS" | grep -qE "(^|/)${pattern}$"; then
      continue  # 삭제는 허용
    fi
    echo -e "${RED}❌ 보안 차단: '${pattern}' 파일은 커밋할 수 없습니다.${NC}"
    echo -e "   → ${YELLOW}git restore --staged \$(git diff --cached --name-only | grep '${pattern}')${NC}"
    BLOCKED=1
  fi
done

# ─── 2. 확장자 기반 차단 ──────────────────────────────────────────────────
BLOCKED_EXTENSIONS=(
  "*.jsonl"
  "*.db"
  "*.db-wal"
  "*.db-shm"
  "*.pem"
  "*.key"
  "*.p12"
  "*.pfx"
)

for ext in "${BLOCKED_EXTENSIONS[@]}"; do
  # 확장자 패턴을 정확한 suffix 매칭 regex로 변환 (*.db → \.db$)
  REGEX=$(echo "$ext" | sed 's/\*\./\\./' | sed 's/$/$/')
  MATCHES=$(echo "$STAGED" | grep -E "$REGEX" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}❌ 보안 차단: '${ext}' 파일 커밋 불가:${NC}"
    echo "$MATCHES" | while read -r f; do echo "   → $f"; done
    echo -e "   → ${YELLOW}git restore --staged <파일명>${NC}"
    BLOCKED=1
  fi
done

# ─── 3. 하드코딩 시크릿 패턴 감지 ────────────────────────────────────────
# staged된 코드/설정 파일에서 의심 패턴 검색 (yaml/yml/sh 포함)
JS_STAGED=$(echo "$STAGED" | grep -E '\.(js|ts|json|yaml|yml|sh|env)$' || true)

if [ -n "$JS_STAGED" ]; then
  # 검사할 패턴 (오탐 최소화를 위해 구체적으로 지정)
  SECRET_PATTERNS=(
    # API 키 패턴 (32자 이상 영숫자, 변수명에 key/secret/token/password 포함)
    "(api_key|api_secret|secret_key|access_key|bot_token|chat_id)\s*[=:]\s*['\"][A-Za-z0-9_\-]{20,}['\"]"
    # 바이낸스/업비트 키 길이
    "['\"][A-Za-z0-9]{64}['\"]"
    # 한국 전화번호 하드코딩 (테스트 화이트리스트 제외)
    "['\"]010-[0-9]{4}-[0-9]{4}['\"]"
  )

  WHITELIST_PHONES=(
    "010-3500-0586"  # 이재룡 (DEV 화이트리스트)
    "010-5435-0586"  # 김정민 (DEV 화이트리스트)
  )

  # 시크릿 검사 제외 파일 (체크섬, 해시 파일 등 오탐 방지)
  SECRET_SKIP_FILES=(
    ".checksums.json"
  )

  for pattern in "${SECRET_PATTERNS[@]}"; do
    while IFS= read -r file; do
      # 제외 파일 스킵
      SKIP=0
      for skip_f in "${SECRET_SKIP_FILES[@]}"; do
        if [[ "$file" == *"$skip_f" ]]; then SKIP=1; break; fi
      done
      [ $SKIP -eq 1 ] && continue
      # git에서 staged 내용 추출
      CONTENT=$(git show ":$file" 2>/dev/null || true)
      MATCHES=$(echo "$CONTENT" | grep -inE "$pattern" || true)

      if [ -n "$MATCHES" ]; then
        # 전화번호 패턴은 화이트리스트 제외
        if [[ "$pattern" == *"010"* ]]; then
          FILTERED=""
          while IFS= read -r line; do
            IS_WHITE=0
            for wp in "${WHITELIST_PHONES[@]}"; do
              if echo "$line" | grep -q "$wp"; then IS_WHITE=1; break; fi
            done
            [ $IS_WHITE -eq 0 ] && FILTERED="$FILTERED\n$line"
          done <<< "$MATCHES"
          MATCHES="$FILTERED"
        fi

        if [ -n "$MATCHES" ]; then
          echo -e "${RED}⚠️  의심 패턴 감지: ${file}${NC}"
          echo "$MATCHES" | head -3 | while read -r line; do
            echo -e "   ${YELLOW}→ $line${NC}"
          done
          BLOCKED=1
        fi
      fi
    done <<< "$JS_STAGED"
  done
fi

# ─── 3.1. retired gateway 재도입 차단 ────────────────────────────────────
RETIRED_GATEWAY_SKIP_REGEX='^(docs/|bots/hub/scripts/.*(legacy-gateway|hub-transition|retired-gateway-marker|runtime-env-policy).*$|scripts/pre-commit$)'
RETIRED_GATEWAY_PATTERNS=(
  'openclaw-gateway'
  'OPENCLAW_BIN'
  '18789'
  'execFile[^\n]*openclaw'
  'spawn[^\n]*openclaw'
)

while IFS= read -r file; do
  [ -z "$file" ] && continue
  if echo "$STAGED_DELETIONS" | grep -qxF "$file"; then continue; fi
  if echo "$file" | grep -Eq "$RETIRED_GATEWAY_SKIP_REGEX"; then continue; fi
  CONTENT=$(git show ":$file" 2>/dev/null || true)
  [ -z "$CONTENT" ] && continue
  for pattern in "${RETIRED_GATEWAY_PATTERNS[@]}"; do
    MATCHES=$(echo "$CONTENT" | grep -inE "$pattern" || true)
    if [ -n "$MATCHES" ]; then
      echo -e "${RED}❌ retired OpenClaw gateway marker 재도입 차단: ${file}${NC}"
      echo "$MATCHES" | head -3 | while read -r line; do
        echo -e "   ${YELLOW}→ $line${NC}"
      done
      BLOCKED=1
    fi
  done
done <<< "$STAGED"

# ─── 3.25. 고신뢰 토큰 시그니처 전체 스캔 ────────────────────────────────
# staged 파일 검사만으로는 provider 고유 토큰 모양을 놓칠 수 있으므로,
# tracked 파일 전체를 값 비노출(redacted) 방식으로 한 번 더 검사한다.
SECRET_LEAK_SMOKE="$REPO_ROOT/bots/hub/scripts/secret-leak-smoke.ts"
TSX_BIN="$REPO_ROOT/node_modules/.bin/tsx"
if [ -f "$SECRET_LEAK_SMOKE" ] && [ -x "$TSX_BIN" ]; then
  if ! "$TSX_BIN" "$SECRET_LEAK_SMOKE"; then
    BLOCKED=1
  fi
else
  echo -e "${YELLOW}⚠️  secret-leak-smoke 실행 불가 — node_modules 설치 후 재검사 권장${NC}"
fi

# ─── 3.5. gitignore 우회 차단 (SEC-005 재발 방지) ────────────────────────
# 이미 추적 중인 파일은 gitignore 효과 없음. staged 파일 중 gitignore 규칙에
# 해당하는 것들은 -f(force) 옵션으로만 추가 가능하므로, 실수로 강제 추적되는
# 것을 방지한다. 특히 docs/codex/는 역사적으로 민감값이 평문으로 들어갔던
# 경로이므로 엄격히 차단.
FORCE_TRACKED_PATHS=(
  "docs/codex/"
  "docs/auto_dev/"
  "docs/strategy/"
  "PATCH_REQUEST.md"
)

for protected in "${FORCE_TRACKED_PATHS[@]}"; do
  MATCHES=$(echo "$STAGED" | grep -E "^${protected}" || true)
  if [ -n "$MATCHES" ] && [ -n "$STAGED_DELETIONS" ]; then
    MATCHES=$(echo "$MATCHES" | grep -vxF -f <(echo "$STAGED_DELETIONS") || true)
  fi
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}❌ gitignore 우회 차단: '${protected}' 경로 파일 커밋 불가${NC}"
    echo "$MATCHES" | while read -r f; do echo "   → $f"; done
    echo -e "   ${YELLOW}→ 이 경로는 .gitignore 등록됨. 추적 중인 파일이면:${NC}"
    echo -e "   ${YELLOW}    git rm --cached <파일명>${NC}"
    echo -e "   ${YELLOW}   새 파일이면 -f 없이 add하지 마세요.${NC}"
    BLOCKED=1
  fi
done

# ─── 4. 결과 ─────────────────────────────────────────────────────────────
if [ $BLOCKED -eq 1 ]; then
  echo ""
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${RED}  커밋 차단됨. 위 문제를 해결한 후 다시 시도하세요.  ${NC}"
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  exit 1
fi

echo -e "${GREEN}✅ 보안 검사 통과${NC}"
exit 0
