# 시그마팀 Constitutional AI 원칙 (Sigma Principles)
#
# 출처: Constitutional AI (arXiv 2212.08073, Bai et al., Anthropic)
# 상위 문서: docs/SIGMA_REMODELING_PLAN_2026-04-17.md §5.3.7
# 보강 문서: docs/SIGMA_REMODELING_RESEARCH_SUPPLEMENT.md §3.3
#
# 용도: 시그마팀이 자율적으로 피드백을 적용하기 전 자기평가(self-critique)하는
#      원칙 목록. Commander가 Directive 실행 직전 이 YAML을 읽어 매 원칙에
#      대해 "이 원칙과 부합하는가"를 판단. 부합하지 않으면 Directive 차단
#      또는 Tier 강등.
#
# 실제 배포 파일: elixir/team_jay/config/sigma_principles.yaml (Phase 0에서 생성)

version: "1.0.0"
last_updated: "2026-04-17"

# ────────────────────────────────────────────────────────────────
# 1. 절대 금지 사항 (Tier 3 Override)
#    어떤 상황에서도 자동 적용하지 않고 마스터 승인 요구
# ────────────────────────────────────────────────────────────────

absolute_prohibitions:
  - id: P-001
    text: "실자금 관련 설정 변경 (거래 한도, 출금 주소, API 키 등)"
    tier_override: 3
    applies_to_teams: [luna, hanul, investment]
    detection_keywords:
      - "withdraw"
      - "transfer_limit"
      - "api_key"
      - "account_number"
      - "wallet_address"

  - id: P-002
    text: "개인정보 관련 설정 변경 (암호화 키, PII 필드 노출 정책)"
    tier_override: 3
    applies_to_teams: [reservation, ska]
    detection_keywords:
      - "encryption_key"
      - "pii_"
      - "phone_enc"
      - "name_enc"

  - id: P-003
    text: "인증/권한 관련 설정 변경 (JWT 시크릿, 역할 매핑, 회사 격리)"
    tier_override: 3
    applies_to_teams: [worker, hub]
    detection_keywords:
      - "jwt_secret"
      - "company_id"
      - "role_"
      - "auth_"

  - id: P-004
    text: "프로덕션 DB 스키마 변경 또는 DROP 문"
    tier_override: 3
    applies_to_teams: [all]
    detection_patterns:
      - "DROP\\s+TABLE"
      - "DROP\\s+SCHEMA"
      - "TRUNCATE"
      - "DELETE\\s+FROM.*WHERE\\s+1=1"

# ────────────────────────────────────────────────────────────────
# 2. Rate Limit (팀별 자동 적용 속도 제한)
#    짧은 시간 내 많은 변경은 시스템 불안정을 유발
# ────────────────────────────────────────────────────────────────

rate_limits:
  - id: P-010
    text: "동일 팀에 24시간 내 Tier 2 변경 최대 3회"
    scope: team
    window_hours: 24
    max_tier2: 3

  - id: P-011
    text: "동일 (team, feedback_type) 조합 72시간 내 재시도 최대 2회"
    scope: team_feedback_pair
    window_hours: 72
    max_retries: 2

  - id: P-012
    text: "전체 시스템 Tier 2 적용 1시간에 최대 5회"
    scope: global
    window_hours: 1
    max_tier2: 5

# ────────────────────────────────────────────────────────────────
# 3. Circuit Breaker (자동 티어 강등)
#    반복 실패 시 자동으로 자율성 축소
# ────────────────────────────────────────────────────────────────

circuit_breakers:
  - id: P-020
    text: "연속 2회 롤백 발생 조합은 Tier 0(관찰만)로 자동 강등"
    trigger:
      metric: rollback_count
      window_hours: 168
      threshold: 2
    action: demote_to_tier
    demote_to_tier: 0
    reset_after_hours: 336  # 2주 후 재승격 검토

  - id: P-021
    text: "일일 Reflexion 노트 > 20건이면 해당 분석가 자동 Tier 0 강등"
    trigger:
      metric: reflexion_count_per_analyst
      window_hours: 24
      threshold: 20
    action: demote_analyst_to_tier
    demote_to_tier: 0

# ────────────────────────────────────────────────────────────────
# 4. Confidence Thresholds (분석가 자신감 기반)
#    자신감 낮을 때 자동 적용 차단
# ────────────────────────────────────────────────────────────────

confidence_thresholds:
  - id: P-030
    text: "분석가 confidence < 0.3일 때 Tier 2 이상 차단"
    min_confidence:
      tier2_plus: 0.3
      tier1: 0.2

  - id: P-031
    text: "newly-hired 분석가 (10회 미만 실행)는 Tier 0만 허용"
    min_execution_count:
      tier1_plus: 10

# ────────────────────────────────────────────────────────────────
# 5. Graduation Criteria (티어 승격 조건)
#    자율성 확장의 학습된 신뢰도 기반 승격
# ────────────────────────────────────────────────────────────────

graduation:
  tier_0_to_1:
    observation_count: 20
    pattern_consistency: 0.7

  tier_1_to_2:
    acceptance_rate: 0.6
    post_acceptance_effectiveness: 0.7
    minimum_samples: 15

  tier_2_to_3:
    # 현재 정책: 자동 승격 불가
    policy: manual_master_approval_only

# ────────────────────────────────────────────────────────────────
# 6. Budget Enforcement (LLM 비용 상한)
#    Paperclip 패턴: 에이전트별 일일/월간 예산
# ────────────────────────────────────────────────────────────────

budgets:
  daily_llm_usd:
    sigma_commander: 3.00
    sigma_analyst_hawk: 1.00
    sigma_analyst_dove: 1.00
    sigma_analyst_owl: 1.00
    sigma_analyst_other: 0.50
    sigma_reflexion: 2.00      # Reflexion 전용 (Haiku)
    sigma_espl_evolve: 5.00    # 주 1회만 소비

  warning_threshold: 0.80      # 80% 소비 시 Telegram 경고
  block_threshold: 1.00        # 100% 소비 시 해당 에이전트 중지

  monthly_llm_usd_total: 180.00  # 시그마팀 전체 월간 상한

# ────────────────────────────────────────────────────────────────
# 7. Self-Critique Prompt Template
#    Commander가 Directive 실행 전 자기평가 시 사용
# ────────────────────────────────────────────────────────────────

self_critique:
  prompt_template: |
    당신은 시그마 Commander입니다. 다음 Directive를 실행하기 전 자기평가하세요.

    [Directive]
    team: {{team}}
    tier: {{tier}}
    action: {{action}}
    analyst: {{analyst}}
    confidence: {{confidence}}

    [원칙 목록]
    {{principles_yaml}}

    [메모리 회상]
    {{recent_reflexions}}

    [질문]
    1. 이 Directive가 P-001~P-004 absolute_prohibitions 중 어느 것이라도 위반하는가?
    2. 최근 24시간 rate_limits (P-010~P-012)에 걸리지 않는가?
    3. circuit_breakers (P-020~P-021)가 현재 활성인가?
    4. confidence_thresholds (P-030~P-031) 충족하는가?

    JSON으로 응답:
    {"approved": bool, "blocked_principles": [...], "suggestion": "..."}

  # 응답이 approved=false면 Directive 차단
  # blocked_principles는 감사 로그에 기록
