# Copy to docker/.env.langfuse and replace every placeholder before starting Langfuse.
# Suggested local generation:
#   openssl rand -base64 32
#   openssl rand -hex 32

LANGFUSE_HOST=http://localhost:3000
LANGFUSE_WEB_PORT=3000
LANGFUSE_CLICKHOUSE_HTTP_PORT=8123
LANGFUSE_REDIS_PORT=6380
LANGFUSE_MINIO_API_PORT=9002
LANGFUSE_MINIO_CONSOLE_PORT=9003
LANGFUSE_MINIO_EXTERNAL_ENDPOINT=http://localhost:9002

# Langfuse v3 queued trace ingestion stores raw events in S3/MinIO.
# Keep region explicit; official Docker examples default this to "auto" for MinIO.
LANGFUSE_S3_EVENT_UPLOAD_REGION=auto
LANGFUSE_S3_BATCH_EXPORT_REGION=auto
LANGFUSE_S3_MEDIA_UPLOAD_REGION=auto
LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/
LANGFUSE_S3_BATCH_EXPORT_PREFIX=exports/
LANGFUSE_S3_MEDIA_UPLOAD_PREFIX=media/

LANGFUSE_DB_PASSWORD=replace-with-random-postgres-password
LANGFUSE_CLICKHOUSE_PASSWORD=replace-with-random-clickhouse-password
LANGFUSE_REDIS_PASSWORD=replace-with-random-redis-password
LANGFUSE_MINIO_ROOT_PASSWORD=replace-with-random-minio-password

LANGFUSE_NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
LANGFUSE_SALT=replace-with-openssl-rand-base64-32
LANGFUSE_ENCRYPTION_KEY=replace-with-64-char-hex-key

# Team Jay OTel export is opt-in. Create Langfuse project keys in the UI first.
LANGFUSE_OTEL_ENABLED=false
LANGFUSE_PROJECT_ID=team-jay-prod
LANGFUSE_PUBLIC_KEY=replace-with-langfuse-public-key
LANGFUSE_SECRET_KEY=replace-with-langfuse-secret-key
LANGFUSE_OTEL_ENDPOINT=http://localhost:3000/api/public/otel

# Optional self-host bootstrap. Keep real values in docker/.env.langfuse only.
LANGFUSE_INIT_ORG_ID=team-jay-org-id
LANGFUSE_INIT_PROJECT_ID=team-jay-prod-id
LANGFUSE_INIT_USER_EMAIL=replace-with-admin-email
LANGFUSE_INIT_USER_PASSWORD=replace-with-strong-admin-password
LANGFUSE_INIT_USER_NAME=Team Jay Admin
LANGFUSE_INIT_ORG_NAME=Team Jay
LANGFUSE_INIT_ORG_CLOUD_PLAN=oss
LANGFUSE_INIT_PROJECT_NAME=Team Jay Production
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=replace-with-init-project-public-key
LANGFUSE_INIT_PROJECT_SECRET_KEY=replace-with-init-project-secret-key
